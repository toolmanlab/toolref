# ============================================================
# ToolRef — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  Never commit .env to version control.
# ============================================================

# ── Application ──────────────────────────────────────────────
DEBUG=false

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=toolref
POSTGRES_PASSWORD=toolref_secret          # CHANGE IN PRODUCTION
POSTGRES_DB=toolref

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                           # leave blank for dev, set in prod
REDIS_DB=0

# ── Milvus ────────────────────────────────────────────────────
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530

# ── MinIO (object storage) ────────────────────────────────────
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin               # CHANGE IN PRODUCTION
MINIO_SECRET_KEY=minioadmin               # CHANGE IN PRODUCTION
MINIO_BUCKET=toolref-documents

# ── Embedding model ───────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=32

# ── Chunking ──────────────────────────────────────────────────
CHUNK_PARENT_SIZE=1024
CHUNK_PARENT_OVERLAP=64
CHUNK_CHILD_SIZE=256
CHUNK_CHILD_OVERLAP=32

# ── LLM provider (ollama | deepseek | openai) ─────────────────
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0.1
OLLAMA_BASE_URL=http://host.docker.internal:11434

# For DeepSeek / OpenAI (uncomment and fill):
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# ── Reranker ──────────────────────────────────────────────────
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=5

# ── Semantic cache ────────────────────────────────────────────
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_DEFAULT_TTL=86400      # 24 hours

# ── RAG retrieval ─────────────────────────────────────────────
GRADING_RELEVANCE_THRESHOLD=0.6
MAX_REWRITE_COUNT=2

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins (used by FastAPI)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── MCP Server ────────────────────────────────────────────────────────────────
# URL of the ToolRef backend API used by the MCP server to execute queries.
# Inside Docker Compose this should point to the backend service name.
# Locally (Claude Desktop stdio mode) it points to localhost.
TOOLREF_API_URL=http://localhost:8000

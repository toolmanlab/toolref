# ──────────────────────────────────────────────────────────────────────────────
# ToolRef — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=ToolRef
APP_VERSION=0.1.0
DEBUG=true

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=toolref
POSTGRES_PASSWORD=toolref_secret
POSTGRES_DB=toolref

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Milvus ───────────────────────────────────────────────────────────────────
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530

# ── MinIO ───────────────────────────────────────────────────────────────────
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=toolref-documents
MINIO_SECURE=false

# ── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=32

# ── Chunking ────────────────────────────────────────────────────────────────
CHUNK_PARENT_SIZE=1024
CHUNK_PARENT_OVERLAP=64
CHUNK_CHILD_SIZE=256
CHUNK_CHILD_OVERLAP=32

# ── LLM ──────────────────────────────────────────────────────────────────────
# Provider: "ollama" | "deepseek" | "openai"
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0.1
OLLAMA_BASE_URL=http://localhost:11434

# API keys (only needed if using cloud providers)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# ── Reranker ─────────────────────────────────────────────────────────────────
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=5

# ── Semantic Cache ───────────────────────────────────────────────────────────
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_DEFAULT_TTL=86400
CACHE_HOT_TTL=259200
CACHE_LOW_FREQ_TTL=43200

# ── RAG Retrieval ────────────────────────────────────────────────────────────
GRADING_RELEVANCE_THRESHOLD=0.6
MAX_REWRITE_COUNT=2
CONSISTENCY_CHECK_ENABLED=false

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

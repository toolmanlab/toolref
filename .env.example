# ──────────────────────────────────────────────────────────────────────────────
# ToolRef — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=ToolRef
APP_VERSION=0.1.0
DEBUG=true

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=toolref
POSTGRES_PASSWORD=toolref_secret
POSTGRES_DB=toolref

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Milvus ───────────────────────────────────────────────────────────────────
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530

# ── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ── LLM ──────────────────────────────────────────────────────────────────────
# Provider: "ollama" | "deepseek" | "openai"
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# API keys (only needed if using cloud providers)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
